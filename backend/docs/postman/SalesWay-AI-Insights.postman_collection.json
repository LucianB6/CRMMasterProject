              },
              {
                "key": "X-Company-Id",
                "value": "{{companyId}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/manager/leads/00000000-0000-0000-0000-000000000000/ai-insights",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "manager",
                "leads",
                "00000000-0000-0000-0000-000000000000",
                "ai-insights"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
