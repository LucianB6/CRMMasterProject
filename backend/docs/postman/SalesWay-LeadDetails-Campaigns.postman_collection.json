  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const reqUrl = pm.request.url.toString();",
          "const isLogin = reqUrl.includes('/auth/login');",
          "if (!isLogin && (!pm.environment.get('jwt') || pm.environment.get('jwt').trim() === '')) {",
          "  conEsole.warn('Lipsește jwt în environment. Rulează mai întâi request-ul Auth/Login.');",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "0. Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Are token', function () {",
                  "  pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.environment.set('jwt', json.token);",
                  "pm.environment.set('userId', json.userId);",
                  "",
                  "try {",
                  "  const payloadPart = json.token.split('.')[1];",
                  "  const normalized = payloadPart.replace(/-/g, '+').replace(/_/g, '/');",
                  "  const decoded = JSON.parse(atob(normalized));",
                  "  if (decoded.companyId) pm.environment.set('companyId', decoded.companyId);",
                  "} catch (e) {",
                  "  console.warn('Nu am putut extrage companyId din JWT:', e);",
                  "}",
                  "",
                  "pm.test('companyId setat', function () {",
                  "  pm.expect(pm.environment.get('companyId')).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
